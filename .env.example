NODE_ENV=development
PORT=3000
# Local dev: postgresql://admin@localhost:5432/mono_reports
# Neon prod:  postgresql://<user>:<pass>@<host>.neon.tech/<db>?sslmode=require
DATABASE_URL=postgresql://admin@localhost:5432/mono_reports
JWT_SECRET=please_generate_a_long_random_secret
JWT_EXPIRES_IN=7d
OWNER_EMAIL=owner@mono.local
OWNER_PASSWORD=changeme123
OWNER_NAME=MONO Owner
# "*" allows any origin. Or list one/several separated by commas (no trailing
# slash), e.g. CORS_ORIGIN=http://localhost:3001,https://mono.vercel.app
CORS_ORIGIN=*
